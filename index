// ============================================================
function handleFileInput(input) {
  var file = input.files[0];
  if (!file) return;
  pendingImageMime = file.type;
  pendingImageName = file.name;
  var reader = new FileReader();
  reader.onload = function(e) {
    var dataUrl = e.target.result;
    pendingImageBase64 = dataUrl.split(',')[1];
    document.getElementById('e-url').value = '';
    document.getElementById('e-preview-img').src = dataUrl;
    document.getElementById('e-preview').style.display = 'block';
  };
  reader.readAsDataURL(file);
  input.value = '';
}

function clearImagen() {
  pendingImageBase64 = pendingImageMime = pendingImageName = null;
  document.getElementById('e-preview').style.display = 'none';
  document.getElementById('e-preview-img').src = '';
}

