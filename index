    var dataStr = JSON.stringify(p).replace(/\\/g, '\\\\').replace(/'/g, "\\'");
    return '<div class="card" style="cursor:pointer" onclick=\'verDetalle("persona",' + dataStr + ')\'>' +
      '<div class="card-header"><div>' +
