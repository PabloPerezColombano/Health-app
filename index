function openModal(tipo, data) {
  var isEdit = !!data;
  if (tipo === 'persona') {
    document.getElementById('modal-persona-title').textContent = isEdit ? 'Editar Persona' : 'Nueva Persona';
    document.getElementById('p-id').value       = data ? data.ID : '';
    document.getElementById('p-nombre').value   = data ? data.Nombre : '';
    document.getElementById('p-fecha').value    = data ? data['Fecha Nacimiento'] : '';
    document.getElementById('p-grupo').value    = data ? data['Grupo Sanguineo'] : '';
    document.getElementById('p-alergias').value = data ? data.Alergias : '';
    document.getElementById('p-notas').value    = data ? data.Notas : '';
  }
  if (tipo === 'consulta') {
    fillPersonaSelect('c-persona', data ? data['Persona ID'] : '');
    document.getElementById('modal-consulta-title').textContent = isEdit ? 'Editar Consulta' : 'Nueva Consulta';
    document.getElementById('c-id').value           = data ? data.ID : '';
    document.getElementById('c-fecha').value        = data ? data.Fecha : '';
    document.getElementById('c-medico').value       = data ? data.Medico : '';
    document.getElementById('c-especialidad').value = data ? data.Especialidad : '';
    document.getElementById('c-motivo').value       = data ? data.Motivo : '';
    document.getElementById('c-diagnostico').value  = data ? data.Diagnostico : '';
    document.getElementById('c-notas').value        = data ? data.Notas : '';
  }
  if (tipo === 'estudio') {
    fillPersonaSelect('e-persona', data ? data['Persona ID'] : '');
    document.getElementById('modal-estudio-title').textContent = isEdit ? 'Editar Estudio' : 'Nuevo Estudio / Análisis';
    document.getElementById('e-id').value          = data ? data.ID : '';
    document.getElementById('e-fecha').value       = data ? data.Fecha : '';
    document.getElementById('e-tipo').value        = data ? data.Tipo : '';
    document.getElementById('e-descripcion').value = data ? data.Descripcion : '';
    document.getElementById('e-laboratorio').value = data ? data.Laboratorio : '';
    document.getElementById('e-url').value         = data ? data['Archivo URL'] : '';
    document.getElementById('e-notas').value       = data ? data.Notas : '';
    clearImagen();
  }
  if (tipo === 'medicamento') {
    fillPersonaSelect('m-persona', data ? data['Persona ID'] : '');
    document.getElementById('modal-medicamento-title').textContent = isEdit ? 'Editar Medicamento' : 'Nuevo Medicamento';
    document.getElementById('m-id').value         = data ? data.ID : '';
    document.getElementById('m-nombre').value     = data ? data.Nombre : '';
    document.getElementById('m-dosis').value      = data ? data.Dosis : '';
    document.getElementById('m-frecuencia').value = data ? data.Frecuencia : '';
    document.getElementById('m-medico').value     = data ? data.Medico : '';
    document.getElementById('m-estado').value     = data ? data.Estado : 'Activo';
    document.getElementById('m-inicio').value     = data ? data['Fecha Inicio'] : '';
    document.getElementById('m-fin').value        = data ? data['Fecha Fin'] : '';
    document.getElementById('m-notas').value      = data ? data.Notas : '';
  }
  document.getElementById('modal-' + tipo).classList.add('open');
}

function closeModal(tipo) {
  document.getElementById('modal-' + tipo).classList.remove('open');
}

// ============================================================
//  MODAL DETALLE
// ============================================================
function verDetalle(tipo, data) {
  var title  = document.getElementById('detalle-title');
  var body   = document.getElementById('detalle-body');
  var footer = document.getElementById('detalle-footer');
  var rows   = [];

  if (tipo === 'consulta') {
    title.textContent = '🩺 Consulta';
    rows = [['Persona', personaNombre(data['Persona ID'])], ['Fecha', fmtFecha(data.Fecha)],
            ['Médico', data.Medico], ['Especialidad', data.Especialidad],
            ['Motivo', data.Motivo], ['Diagnóstico', data.Diagnostico], ['Notas', data.Notas]];
  } else if (tipo === 'estudio') {
    title.textContent = '🔬 Estudio / Análisis';
    rows = [['Persona', personaNombre(data['Persona ID'])], ['Fecha', fmtFecha(data.Fecha)],
            ['Tipo', data.Tipo], ['Descripción', data.Descripcion],
            ['Laboratorio', data.Laboratorio], ['Notas', data.Notas]];
  } else if (tipo === 'medicamento') {
    title.textContent = '💊 Medicamento';
    rows = [['Persona', personaNombre(data['Persona ID'])], ['Nombre', data.Nombre],
            ['Dosis', data.Dosis], ['Frecuencia', data.Frecuencia], ['Médico', data.Medico],
            ['Estado', data.Estado], ['Desde', fmtFecha(data['Fecha Inicio'])],
            ['Hasta', fmtFecha(data['Fecha Fin'])], ['Notas', data.Notas]];
  } else if (tipo === 'persona') {
    title.textContent = '👤 Persona';
    rows = [['Nombre', data.Nombre], ['Nacimiento', fmtFecha(data['Fecha Nacimiento'])],
            ['Grupo sanguíneo', data['Grupo Sanguineo']], ['Alergias', data.Alergias], ['Notas', data.Notas]];
  }

  body.innerHTML = rows.filter(function(r) { return r[1]; }).map(function(r) {
    return '<div style="display:flex;gap:10px;padding:8px 0;border-bottom:1px solid var(--gray-100)">' +
      '<span style="font-size:0.78rem;font-weight:600;color:var(--gray-400);min-width:110px">' + r[0] + '</span>' +
      '<span style="font-size:0.88rem;color:var(--gray-800)">' + r[1] + '</span></div>';
  }).join('');

  var archivoUrl = data['Archivo URL'];
  var dataStr = JSON.stringify(data).replace(/\\/g, '\\\\').replace(/'/g, "\\'");
  footer.innerHTML =
    (archivoUrl ? '<a href="' + archivoUrl + '" target="_blank" class="btn btn-primary">📎 Ver archivo</a>' : '') +
    '<button class="btn btn-outline" onclick=\'openModal("' + tipo + '",' + dataStr + ');closeModal("detalle")\'>✏️ Editar</button>' +
    '<button class="btn btn-outline" onclick="closeModal(\'detalle\')">Cerrar</button>';

  document.getElementById('modal-detalle').classList.add('open');
}

// ============================================================
