// ============================================================
//  TIMELINE
// ============================================================
function renderTimelinePersonas() {
  var el = document.getElementById('lista-timeline');
  if (!personas.length) { el.innerHTML = empty('No hay personas registradas'); return; }
  el.innerHTML = personas.map(function(p) {
    var pid = String(p.ID);
    var eventos = []
      .concat(consultas.filter(function(c) { return String(c['Persona ID']) === pid; })
        .map(function(c) { return Object.assign({}, c, {_tipo:'consulta', _fecha:c.Fecha}); }))
      .concat(estudios.filter(function(e) { return String(e['Persona ID']) === pid; })
        .map(function(e) { return Object.assign({}, e, {_tipo:'estudio', _fecha:e.Fecha}); }))
      .concat(medicamentos.filter(function(m) { return String(m['Persona ID']) === pid; })
        .map(function(m) { return Object.assign({}, m, {_tipo:'medicamento', _fecha:m['Fecha Inicio']}); }))
      .filter(function(e) { return e._fecha; })
      .sort(function(a,b) { return b._fecha > a._fecha ? 1 : -1; });
    return '<div class="card" style="margin-bottom:12px">' +
      '<div class="card-header" style="cursor:pointer" onclick="toggleTimeline(\'tl-' + pid + '\',\'arr-' + pid + '\')">' +
      '<div><div class="card-title">👤 ' + p.Nombre + '</div>' +
      '<div class="card-sub">' + eventos.length + ' evento' + (eventos.length !== 1 ? 's' : '') + '</div></div>' +
      '<span id="arr-' + pid + '" style="font-size:1.2rem;color:var(--gray-400)">▶</span></div>' +
      '<div id="tl-' + pid + '" style="display:none;margin-top:12px">' +
      (eventos.length ? renderTLEventos(eventos) : '<div class="empty" style="padding:16px"><span style="font-size:1.5rem">📭</span>Sin eventos</div>') +
      '</div></div>';
  }).join('');
}

function toggleTimeline(tlId, arrId) {
  var el  = document.getElementById(tlId);
  var arr = document.getElementById(arrId);
  var open = el.style.display === 'none';
  el.style.display = open ? 'block' : 'none';
  arr.textContent  = open ? '▼' : '▶';
}

function renderTLEventos(eventos) {
  return '<div class="timeline">' + eventos.map(function(ev) {
    var dot = '', title = '', tipo = ev._tipo;
    if (tipo === 'consulta')    { dot = '';       title = '🩺 ' + (ev.Medico || 'Consulta') + (ev.Especialidad ? ' · ' + ev.Especialidad : ''); }
    else if (tipo === 'estudio')     { dot = 'orange'; title = '🔬 ' + (ev.Descripcion || ev.Tipo || 'Estudio'); }
    else                             { dot = 'green';  title = '💊 ' + ev.Nombre; }
    var dataStr = JSON.stringify(ev).replace(/\\/g, '\\\\').replace(/'/g, "\\'");
    return '<div class="tl-item"><div class="tl-dot ' + dot + '"></div>' +
      '<div class="tl-date">' + fmtFecha(ev._fecha) + '</div>' +
      '<div class="card" style="margin-bottom:0;cursor:pointer" onclick=\'verDetalle("' + tipo + '",' + dataStr + ')\'>' +
      '<div class="card-title">' + title + '</div>' +
      (ev['Archivo URL'] ? '<div class="card-body"><p>📎 Tiene archivo adjunto</p></div>' : '') +
      '</div></div>';
  }).join('') + '</div>';
}

